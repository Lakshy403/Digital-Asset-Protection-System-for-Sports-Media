rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Media Library ──
    // Authenticated users can read all media and create new entries.
    // Only Cloud Functions (admin SDK) can update/delete.
    match /mediaLibrary/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── User Settings (per-user preferences) ──
    // Each user can read/write only their own settings document.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── User profiles ──
    match /users/{userId} {
      allow read:            if request.auth != null;
      allow create, update:  if request.auth != null && request.auth.uid == userId;
      allow delete:          if false;
    }

    // ── Violations (created by Cloud Functions, read by clients) ──
    match /violations/{docId} {
      allow read:   if request.auth != null;
      allow write:  if false; // admin SDK only
    }

    // ── Security Scans (created by Cloud Functions, read by clients) ──
    match /securityScans/{docId} {
      allow read:   if request.auth != null;
      allow write:  if false; // admin SDK only
    }

    // ── Alerts / notifications ──
    match /alerts/{alertId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Deny everything else by default ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
